{
  "name": "@scrollpop/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ScrollPop Desktop — self-contained local app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm --filter @scrollpop/dashboard build && electron-vite build",
    "preview": "electron-vite preview",
    "package": "pnpm run build && electron-builder",
    "package:win": "pnpm run build && electron-builder --win",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.32.0",
    "electron-updater": "^6.3.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "sql.js": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.9",
    "drizzle-kit": "^0.23.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0"
  }
}
